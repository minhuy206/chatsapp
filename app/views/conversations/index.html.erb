<% content_for :title, "All Conversations" %>

<!-- Header with Top Bar -->
<div class="flex items-center justify-between px-6 py-3 border-b border-gray-700">
  <div class="flex items-center space-x-4">
    <%= link_to root_path, class: "flex items-center space-x-2 text-gray-400 hover:text-white transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <span class="text-sm font-medium">Home</span>
    <% end %>
    <h1 class="text-xl font-semibold text-white">All Conversations</h1>
  </div>

  <div class="flex items-center space-x-3">
    <%= link_to "New Chat", new_conversation_path, class: "bg-gradient-to-r from-blue-600 to-purple-600 text-white px-4 py-2 rounded-lg font-medium hover:from-blue-700 hover:to-purple-700 transition-all" %>
  </div>
</div>

<!-- Main Content -->
<div class="flex-1 px-6 py-6">
  <div class="max-w-4xl mx-auto">
    <% if @conversations.any? %>
      <div class="space-y-3">
        <% @conversations.each do |conversation| %>
          <div class="bg-gray-800 border border-gray-700 rounded-xl hover:border-gray-600 transition-colors">
            <div class="p-4 flex items-center justify-between">
              <%= link_to conversation_path(conversation), class: "flex-1 flex items-center min-w-0 group" do %>
                <div class="flex-shrink-0">
                  <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.959 8.959 0 01-4.906-1.405L3 21l2.595-5.094A8.96 8.96 0 013 12c0-4.418 3.582-8 8-8s8 3.582 8 8z"></path>
                    </svg>
                  </div>
                </div>
                <div class="ml-4 flex-1 min-w-0">
                  <div class="text-sm font-medium text-white truncate group-hover:text-blue-400 transition-colors">
                    <%= conversation.title %>
                  </div>
                  <div class="text-sm text-gray-400 flex items-center space-x-3 mt-1">
                    <span><%= conversation.ai_model_display_name %></span>
                    <span>•</span>
                    <span><%= pluralize(conversation.message_count, 'message') %></span>
                    <span>•</span>
                    <span><%= time_ago_in_words(conversation.updated_at) %> ago</span>
                  </div>
                  <% if conversation.latest_message %>
                    <div class="text-sm text-gray-500 mt-2 truncate">
                      <%= truncate(conversation.latest_message.content, length: 120) %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <div class="ml-4 flex-shrink-0">
                <%= link_to conversation_path(conversation, method: :delete),
                    data: {
                      confirm: "Are you sure you want to delete this conversation?",
                      turbo_method: :delete
                    },
                    class: "p-2 text-gray-400 hover:text-red-400 transition-colors" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <div class="w-16 h-16 bg-gray-800 border border-gray-700 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.959 8.959 0 01-4.906-1.405L3 21l2.595-5.094A8.96 8.96 0 013 12c0-4.418 3.582-8 8-8s8 3.582 8 8z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-white mb-2">No conversations yet</h3>
        <p class="text-gray-400 mb-8">Get started by creating your first AI conversation.</p>
        <%= link_to "Start Your First Chat", new_conversation_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 transition-all shadow-lg" %>
      </div>
    <% end %>
  </div>
</div>
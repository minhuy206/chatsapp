<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "AI Chat" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-900 text-white antialiased">
    <div class="flex h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-gray-800 border-r border-gray-700 flex flex-col">
        <!-- Logo -->
        <div class="p-4 border-b border-gray-700">
          <%= link_to root_path, class: "flex items-center space-x-2 text-white hover:text-gray-300" do %>
            <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.959 8.959 0 01-4.906-1.405L3 21l2.595-5.094A8.96 8.96 0 013 12c0-4.418 3.582-8 8-8s8 3.582 8 8z"></path>
              </svg>
            </div>
            <span class="font-semibold text-lg">AI Chat</span>
          <% end %>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-4 space-y-2">
          <%= link_to root_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 text-white transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            <span class="font-medium">New Chat</span>
            <div class="ml-auto flex items-center space-x-1 text-xs text-gray-400">
              <kbd class="px-1 py-0.5 bg-gray-600 rounded text-xs">⌘</kbd>
              <kbd class="px-1 py-0.5 bg-gray-600 rounded text-xs">K</kbd>
            </div>
          <% end %>

          <!-- AI Model Selector -->
          <div class="mt-6 mb-4" data-controller="ai-model-modal sidebar-model-selector">
            <!-- Selected Model Display -->
            <button type="button"
                    data-action="click->ai-model-modal#openModal"
                    class="w-full flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 text-white transition-colors text-left">
              <div class="w-6 h-6 bg-gradient-to-br from-green-500 to-emerald-600 rounded-md flex items-center justify-center flex-shrink-0" data-ai-model-modal-target="selectedIcon">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <div class="text-sm font-medium" data-ai-model-modal-target="selectedName">GPT-4o</div>
                <div class="text-xs text-gray-400" data-ai-model-modal-target="selectedDescription">Latest OpenAI model with enhanced multimodal capabilities</div>
              </div>
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <!-- Modal Backdrop -->
            <div class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden"
                 data-ai-model-modal-target="backdrop"
                 data-action="click->ai-model-modal#closeModal"></div>

            <!-- Modal -->
            <div class="fixed inset-y-0 left-0 w-96 bg-gray-800 border-r border-gray-700 z-50 transform -translate-x-full transition-transform duration-300 ease-in-out hidden"
                 data-ai-model-modal-target="modal">

              <!-- Modal Header -->
              <div class="flex items-center justify-between p-4 border-b border-gray-700">
                <h2 class="text-lg font-semibold text-white">Choose AI Model</h2>
                <button type="button"
                        data-action="click->ai-model-modal#closeModal"
                        class="text-gray-400 hover:text-white">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </button>
              </div>

              <!-- Modal Content -->
              <div class="p-4 space-y-6 overflow-y-auto h-full">

                <!-- OpenAI Models Section -->
                <div>
                  <h3 class="text-sm font-medium text-gray-400 mb-3">OpenAI Models</h3>
                  <div class="space-y-3">
                    <!-- GPT-4o -->
                    <button type="button"
                            data-model="gpt-4o"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-green-500 to-emerald-600 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="flex items-center space-x-2">
                          <span class="text-sm font-medium text-white">GPT-4o</span>
                          <span class="px-2 py-0.5 bg-blue-600 text-xs text-white rounded-full">Latest</span>
                        </div>
                        <p class="text-xs text-gray-400 mt-1">Latest OpenAI model with enhanced multimodal capabilities</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="gpt-4o" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>

                    <!-- GPT-4 -->
                    <button type="button"
                            data-model="gpt-4"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="text-sm font-medium text-white">GPT-4</div>
                        <p class="text-xs text-gray-400 mt-1">Powerful reasoning and complex problem-solving capabilities</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="gpt-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>

                    <!-- GPT-3.5 Turbo -->
                    <button type="button"
                            data-model="gpt-3.5-turbo"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-blue-400 to-purple-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="text-sm font-medium text-white">GPT-3.5 Turbo</div>
                        <p class="text-xs text-gray-400 mt-1">Fast and efficient for everyday tasks and conversations</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="gpt-3.5-turbo" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>
                  </div>
                </div>

                <!-- Anthropic Models Section -->
                <div>
                  <h3 class="text-sm font-medium text-gray-400 mb-3">Anthropic Models</h3>
                  <div class="space-y-3">
                    <!-- Claude 3.5 Sonnet -->
                    <button type="button"
                            data-model="claude-3.5-sonnet"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-orange-500 to-red-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="flex items-center space-x-2">
                          <span class="text-sm font-medium text-white">Claude 3.5 Sonnet</span>
                          <span class="px-2 py-0.5 bg-orange-600 text-xs text-white rounded-full">Latest</span>
                        </div>
                        <p class="text-xs text-gray-400 mt-1">Latest Claude model with enhanced reasoning and analysis</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="claude-3.5-sonnet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>

                    <!-- Claude 3 Opus -->
                    <button type="button"
                            data-model="claude-3-opus"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-purple-600 to-pink-600 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="text-sm font-medium text-white">Claude 3 Opus</div>
                        <p class="text-xs text-gray-400 mt-1">Most capable Claude model for complex reasoning tasks</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="claude-3-opus" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>

                    <!-- Claude 3 Sonnet -->
                    <button type="button"
                            data-model="claude-3-sonnet"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-orange-400 to-red-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="text-sm font-medium text-white">Claude 3 Sonnet</div>
                        <p class="text-xs text-gray-400 mt-1">Balanced performance for most tasks and conversations</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="claude-3-sonnet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>

                    <!-- Claude 3 Haiku -->
                    <button type="button"
                            data-model="claude-3-haiku"
                            data-action="click->ai-model-modal#selectModel"
                            class="model-option w-full flex items-start space-x-3 p-3 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-8 h-8 bg-gradient-to-br from-teal-500 to-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="text-sm font-medium text-white">Claude 3 Haiku</div>
                        <p class="text-xs text-gray-400 mt-1">Fast and efficient for quick responses and simple tasks</p>
                      </div>
                      <svg class="w-5 h-5 text-green-500 opacity-0" data-check="claude-3-haiku" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </button>
                  </div>
                </div>

                <!-- Recents Section -->
                <div>
                  <h3 class="text-sm font-medium text-gray-400 mb-3">Recents</h3>
                  <div class="space-y-2">
                    <button type="button" class="w-full flex items-center space-x-3 p-2 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-6 h-6 bg-gradient-to-br from-purple-500 to-pink-600 rounded-md flex items-center justify-center flex-shrink-0">
                        <span class="text-xs font-medium text-white">G</span>
                      </div>
                      <span class="text-sm text-white">GPT-4o</span>
                      <svg class="w-4 h-4 text-gray-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </button>

                    <button type="button" class="w-full flex items-center space-x-3 p-2 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-6 h-6 bg-gradient-to-br from-gray-500 to-gray-600 rounded-md flex items-center justify-center flex-shrink-0">
                        <span class="text-xs font-medium text-white">R</span>
                      </div>
                      <span class="text-sm text-white">Research</span>
                      <svg class="w-4 h-4 text-gray-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </button>

                    <button type="button" class="w-full flex items-center space-x-3 p-2 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-6 h-6 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-md flex items-center justify-center flex-shrink-0">
                        <span class="text-xs font-medium text-white">C</span>
                      </div>
                      <span class="text-sm text-white">Compute</span>
                      <svg class="w-4 h-4 text-gray-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </button>

                    <button type="button" class="w-full flex items-center space-x-3 p-2 rounded-lg hover:bg-gray-700 transition-colors text-left">
                      <div class="w-6 h-6 bg-gradient-to-br from-green-500 to-teal-600 rounded-md flex items-center justify-center flex-shrink-0">
                        <span class="text-xs font-medium text-white">C</span>
                      </div>
                      <span class="text-sm text-white">Create</span>
                      <svg class="w-4 h-4 text-gray-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </button>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <%= link_to conversations_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 text-gray-300 hover:text-white transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            <span>Projects</span>
            <span class="ml-auto bg-blue-600 text-xs px-2 py-0.5 rounded-full">NEW</span>
          <% end %>

          <div class="flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 text-gray-300 hover:text-white transition-colors cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>Agents</span>
          </div>
        </nav>

        <!-- Today Section -->
        <div class="p-4 border-t border-gray-700">
          <h3 class="text-sm font-medium text-gray-400 mb-2">Today</h3>
          <!-- Recent conversations will be dynamically loaded here -->
        </div>

        <!-- Bottom Section -->
        <div class="p-4 border-t border-gray-700">
          <div class="space-y-2">
            <div class="flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 text-gray-300 hover:text-white transition-colors cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
              <span>Business</span>
            </div>

            <div class="flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 text-gray-300 hover:text-white transition-colors cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <span>Download</span>
            </div>

            <div class="flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 text-gray-300 hover:text-white transition-colors cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z"></path>
              </svg>
              <span>More</span>
            </div>
          </div>

          <!-- User Profile -->
          <div class="mt-4 flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition-colors cursor-pointer">
            <div class="w-8 h-8 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center text-white font-semibold text-sm">
              U
            </div>
            <div class="flex-1">
              <div class="text-sm font-medium text-white">User</div>
              <div class="text-xs text-gray-400">Free plan</div>
            </div>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>

          <!-- Upgrade Button -->
          <div class="mt-3">
            <button class="w-full bg-gradient-to-r from-blue-600 to-purple-600 text-white py-2 px-4 rounded-lg font-medium hover:from-blue-700 hover:to-purple-700 transition-all">
              Upgrade
            </button>
          </div>
        </div>
      </aside>

      <!-- Main Content -->

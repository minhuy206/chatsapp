<div id="conversation-item-<%= conversation.id %>"
     class="conversation-item group relative p-3 rounded-lg cursor-pointer hover:bg-gray-700 transition-colors <%= 'bg-gray-700' if current %>"
     data-action="click->home-chat#loadConversation"
     data-conversation-id="<%= conversation.id %>"
     data-home-chat-title-value="<%= conversation.title %>">

  <div class="flex items-start justify-between">
    <div class="flex-1 min-w-0">
      <div id="conversation-title-<%= conversation.id %>" class="conversation-title font-medium text-white text-sm truncate mb-1">
        <%= conversation.title %>
      </div>

      <div class="flex items-center space-x-2 text-xs text-gray-400">
        <span class="ai-model-badge bg-blue-900 text-blue-200 px-2 py-0.5 rounded">
          <%= conversation.ai_model_display_name %>
        </span>
        <span class="timestamp">
          <%= time_ago_in_words(conversation.updated_at) %> ago
        </span>
      </div>

      <% if conversation.messages.any? %>
        <div class="last-message mt-2 text-xs text-gray-500 truncate">
          <%= truncate(conversation.messages.last.content, length: 60) %>
        </div>
      <% end %>
    </div>

    <div class="flex items-center space-x-1 opacity-0 group-hover:opacity-100 transition-opacity">
      <button data-action="click->home-chat#editTitle"
              data-conversation-id="<%= conversation.id %>"
              class="p-1 hover:bg-gray-600 rounded text-gray-400 hover:text-white"
              title="Edit title">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
      </button>

      <button data-action="click->home-chat#deleteConversation"
              data-conversation-id="<%= conversation.id %>"
              class="p-1 hover:bg-red-600 rounded text-gray-400 hover:text-red-200"
              title="Delete conversation">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
      </button>
    </div>
  </div>
</div>
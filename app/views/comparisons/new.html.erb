<% content_for :title, "Compare AI Models" %>

<%= turbo_stream_from "comparison_chat" %>

<div class="flex h-screen bg-gray-900">
  <!-- Sidebar for Navigation -->
  <div class="w-80 bg-gray-800 border-r border-gray-700 flex flex-col">
    <div class="p-4 border-b border-gray-700">
      <div class="flex items-center space-x-3 mb-4">
        <%= link_to root_path, class: "flex items-center space-x-2 text-gray-400 hover:text-white transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          <span class="text-sm">Single Chat</span>
        <% end %>
      </div>

      <h1 class="text-xl font-bold text-white flex items-center space-x-2">
        <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <span>AI Arena</span>
      </h1>
      <p class="text-sm text-gray-400 mt-1">Compare responses from different models</p>
    </div>

    <!-- Previous Comparisons -->
    <div class="flex-1 overflow-y-auto p-4">
      <h3 class="text-sm font-medium text-gray-300 mb-3">Recent Comparisons</h3>
      <div class="space-y-2">
        <% if @conversations&.any? %>
          <% @conversations.each do |comparison| %>
            <%= link_to comparison_path(comparison),
                class: "block p-3 rounded-lg bg-gray-700 hover:bg-gray-600 transition-colors" do %>
              <div class="text-sm font-medium text-white truncate">
                <%= comparison.comparison_title %>
              </div>
              <div class="text-xs text-gray-400 mt-1">
                <%= time_ago_in_words(comparison.updated_at) %> ago
              </div>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500">No comparisons yet</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Main Comparison Area -->
  <div class="flex-1 flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-700 bg-gray-800">
      <div>
        <h2 class="text-lg font-semibold text-white">New Model Comparison</h2>
        <p class="text-sm text-gray-400">Select two models to compare their responses</p>
      </div>
    </div>

    <!-- Comparison Interface -->
    <div id="comparison-area" class="flex-1 flex flex-col">
      <%= render partial: "shared/comparison_setup", locals: { ai_models: @ai_models } %>
    </div>
  </div>
</div>
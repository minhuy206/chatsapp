<%= turbo_stream.append "messages" do %>
  <%= render partial: 'messages/message', locals: { message: @message } %>
<% end %>

<%= turbo_stream.replace "message-form" do %>
  <%= render partial: 'messages/form', locals: { conversation: @conversation, message: Message.new } %>
<% end %>

<%= turbo_stream.append "messages" do %>
  <div id="typing-indicator" class="flex justify-start">
    <div class="max-w-xs lg:max-w-md xl:max-w-lg">
      <div class="bg-white rounded-lg px-4 py-2 shadow border">
        <div class="flex items-center space-x-2">
          <div class="flex-shrink-0">
            <div class="w-6 h-6 bg-gray-200 rounded-full flex items-center justify-center">
              <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
          </div>
          <div class="flex space-x-1">
            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce"></div>
            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.1s;"></div>
            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.2s;"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>